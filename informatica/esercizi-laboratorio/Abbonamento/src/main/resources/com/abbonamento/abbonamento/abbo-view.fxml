<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="266.0" prefWidth="278.0" spacing="15.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.abbonamento.abbonamento.AbbonamentoController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <!-- RadioButton per il tipo di abbonamento -->
    <RadioButton fx:id="mensile" text="Mensile" />
    <RadioButton fx:id="semestrale" text="Semestrale" />
    <RadioButton fx:id="annuale" text="Annuale" />

    <!-- DatePicker per la data di inizio -->
    <DatePicker fx:id="datePicker" />

    <!-- Bottone per calcolare la data di fine -->
    <Button onAction="#onCalcolaButtonClick" text="Fine" />

    <!-- Label per mostrare la data di fine -->
    <Label fx:id="welcomeText" />
</VBox>
